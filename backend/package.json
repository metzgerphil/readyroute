{
  "name": "readyroute-backend",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon --watch src --ext js,json src/index.js",
    "seed:auth": "node src/scripts/seedAuthUsers.js",
    "seed:manager": "node src/scripts/addManagerUser.js",
    "test:unit": "node --test src/**/*.test.js",
    "test:e2e": "jest --runInBand tests/e2e.test.js",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "axios": "^1.8.4",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "stripe": "^22.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2"
  }
}
