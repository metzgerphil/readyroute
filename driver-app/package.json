{
  "name": "driver-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "check": "HOME=/tmp/readyroute-expo-home expo config --json > /dev/null",
    "check:release": "node ./scripts/check-release-env.js --production",
    "build:native": "HOME=/tmp/readyroute-expo-home expo export --platform ios --output-dir dist-native",
    "build:native:production": "NODE_ENV=production HOME=/tmp/readyroute-expo-home expo export --platform ios --output-dir dist-native-production",
    "build:web": "npm run build:native",
    "test": "jest --runInBand --forceExit",
    "release:prep": "npm run check && npm run test && npm run build:native:production && npm run check:release"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/stack": "^7.8.9",
    "axios": "^1.15.0",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-file-system": "~19.0.21",
    "expo-location": "~19.0.8",
    "expo-status-bar": "~3.0.9",
    "jest-expo": "~54.0.17",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.4",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "^0.21.0"
  },
  "private": true,
  "devDependencies": {
    "@testing-library/react-native": "^13.2.0",
    "jest": "^29.7.0",
    "react-test-renderer": "^19.1.0"
  },
  "jest": {
    "preset": "jest-expo"
  }
}
